<Window x:Class="Scribe.App.Overlay.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Focusable="False"
        Width="248" Height="68">
    <Window.Resources>
        <Storyboard x:Key="PulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="RecDot"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.25" Duration="0:0:0.7"/>
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="16" Padding="14,10"
            Background="#E6202124" BorderBrush="#26FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.55" Color="#FF000000"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Ellipse x:Name="RecDot" Grid.Column="0" Width="12" Height="12"
                     Margin="2,0,12,0" Fill="#E5484D" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" Text="Listening…"
                           Foreground="#FFFFFFFF" FontSize="13" FontWeight="SemiBold"/>
                <Border Margin="0,8,0,0" Width="168" Height="6" CornerRadius="3"
                        Background="#33FFFFFF" HorizontalAlignment="Left">
                    <Border x:Name="MeterFill" HorizontalAlignment="Left" Width="0" CornerRadius="3">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#34D399" Offset="0.0"/>
                                <GradientStop Color="#FBBF24" Offset="0.7"/>
                                <GradientStop Color="#E5484D" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>

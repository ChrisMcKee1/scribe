<Window x:Class="Scribe.App.Overlay.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Focusable="False"
        Width="364" Height="180">
    <Window.Resources>
        <Storyboard x:Key="PulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="RecDot"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.25" Duration="0:0:0.7"/>
        </Storyboard>
        <Storyboard x:Key="ProcessingStoryboard">
            <DoubleAnimation Storyboard.TargetName="Dot1"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-5" Duration="0:0:0.45" AutoReverse="True"
                             RepeatBehavior="Forever" BeginTime="0:0:0">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Dot2"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-5" Duration="0:0:0.45" AutoReverse="True"
                             RepeatBehavior="Forever" BeginTime="0:0:0.12">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Dot3"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-5" Duration="0:0:0.45" AutoReverse="True"
                             RepeatBehavior="Forever" BeginTime="0:0:0.24">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <!-- Strong outer glow: a bright rounded stroke whose bloom radiates around the pill at full
             intensity. A null fill keeps the glass card above it see-through (no opaque backing). -->
        <Border x:Name="OuterGlow" Margin="60" CornerRadius="23" BorderThickness="2"
                Background="{x:Null}" BorderBrush="#FF8FB2FF" IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect BlurRadius="44" ShadowDepth="0" Opacity="1" Color="#7FA6FF"/>
            </Border.Effect>
        </Border>
        <!-- Red outer glow, shown only during the brief "intelligence failed" flash. -->
        <Border x:Name="OuterGlowFailed" Margin="60" CornerRadius="23" BorderThickness="2"
                Background="{x:Null}" BorderBrush="#FFE5484D" IsHitTestVisible="False"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="44" ShadowDepth="0" Opacity="1" Color="#E5484D"/>
            </Border.Effect>
        </Border>
        <Border x:Name="Card" Margin="60" CornerRadius="22" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#802B2F38" Offset="0.0"/>
                    <GradientStop Color="#73191C22" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#4DFFFFFF" Offset="0.0"/>
                    <GradientStop Color="#0DFFFFFF" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect BlurRadius="48" ShadowDepth="0" Opacity="0.95" Color="#7FA6FF"/>
            </Border.Effect>
            <Grid>
                <!-- Specular sheen across the top so the panel reads like glass -->
                <Border CornerRadius="22,22,0,0" VerticalAlignment="Top" Height="32" IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#1AFFFFFF" Offset="0.0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Red wash over the card face during the brief AI-failure flash. Rendered before the
                     content grid so the failure text stays on top of it. -->
                <Border x:Name="FailedTint" CornerRadius="22" Visibility="Collapsed" IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#E6B3261A" Offset="0.0"/>
                            <GradientStop Color="#D98C1410" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="48" ShadowDepth="0" Opacity="0.95" Color="#E5484D"/>
                    </Border.Effect>
                </Border>

                <Grid Margin="16,11">
                    <!-- Listening: pulsing record dot + live input-level meter -->
                    <Grid x:Name="ListeningContent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Ellipse x:Name="RecDot" Grid.Column="0" Width="12" Height="12"
                                 Margin="2,0,12,0" Fill="#E5484D" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusText" Text="Listening…"
                                       Foreground="#FFFFFFFF" FontSize="13" FontWeight="SemiBold"/>
                            <Border Margin="0,8,0,0" Width="168" Height="6" CornerRadius="3"
                                    Background="#26FFFFFF" HorizontalAlignment="Left">
                                <Border x:Name="MeterFill" HorizontalAlignment="Left" Width="0" CornerRadius="3">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#34D399" Offset="0.0"/>
                                            <GradientStop Color="#FBBF24" Offset="0.7"/>
                                            <GradientStop Color="#E5484D" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Processing: bouncing dots while transcribing / AI polishing -->
                    <Grid x:Name="ProcessingContent" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="2,0,12,0">
                            <Ellipse x:Name="Dot1" Width="8" Height="8" Margin="0,0,5,0" Fill="#8AB4F8"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="Dot2" Width="8" Height="8" Margin="0,0,5,0" Fill="#8AB4F8"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="#8AB4F8"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform><TranslateTransform/></Ellipse.RenderTransform>
                            </Ellipse>
                        </StackPanel>

                        <TextBlock x:Name="ProcessingText" Grid.Column="1" Text="Polishing…"
                                   VerticalAlignment="Center" Foreground="#FFFFFFFF"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </Grid>

                    <!-- AI cleanup failed: a brief red notice shown while falling back to raw text -->
                    <Grid x:Name="FailedContent" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="&#x26A0;" VerticalAlignment="Center"
                                   Margin="2,0,12,0" FontSize="18" Foreground="#FFFFFFFF"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Intelligence failed" Foreground="#FFFFFFFF"
                                       FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="FailedReasonText" Text="Used raw transcription"
                                       Foreground="#D6FFFFFF" FontSize="11" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

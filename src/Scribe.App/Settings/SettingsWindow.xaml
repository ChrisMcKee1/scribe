<ui:FluentWindow x:Class="Scribe.App.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Scribe Settings"
        Width="1100" Height="800" MinWidth="940" MinHeight="660"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">
    <ui:FluentWindow.Resources>
        <!-- Page header shown at the top of every section, Windows Settings style. -->
        <Style TargetType="TextBlock" x:Key="PageTitle">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="PageSubtitle">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="GroupHeader">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="2,20,0,10"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="SettingTitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="SettingHint">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>
        <Style TargetType="ui:Card" x:Key="SettingCard">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="18,14"/>
        </Style>
        <!-- Master-detail cards must fill their grid cell; ui:Card centres by default. -->
        <Style TargetType="ui:Card" x:Key="FillCard">
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <!-- One clickable zone of the overlay-position picker: an invisible cell that reveals a
             ghost pill on hover and an accent-coloured pill when selected. -->
        <Style TargetType="RadioButton" x:Key="OverlayZone">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Cell" CornerRadius="6" Background="Transparent">
                            <Border x:Name="Pill" Width="48" Height="16" CornerRadius="8"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    Opacity="0">
                                <Ellipse Width="5" Height="5" Fill="#E5484D"
                                         HorizontalAlignment="Left" VerticalAlignment="Center"
                                         Margin="8,0,0,0"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Cell" Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                <Setter TargetName="Pill" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill" Property="Opacity" Value="1"/>
                                <Setter TargetName="Pill" Property="Background"
                                        Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Scribe Settings">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Mic24"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="232"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left navigation rail -->
            <ListBox x:Name="NavList" Grid.Column="0" Margin="8,4,4,16"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectedIndex="0" SelectionChanged="NavList_SelectionChanged">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="Padding" Value="12,10"/>
                        <Setter Property="Margin" Value="0,2"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="18"/>
                        <TextBlock Text="General" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Mic24" FontSize="18"/>
                        <TextBlock Text="Dictation" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Desktop24" FontSize="18"/>
                        <TextBlock Text="Overlay" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Wand24" FontSize="18"/>
                        <TextBlock Text="AI cleanup" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Book24" FontSize="18"/>
                        <TextBlock Text="Dictionary" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Library24" FontSize="18"/>
                        <TextBlock Text="Libraries" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="TextQuote24" FontSize="18"/>
                        <TextBlock Text="Snippets" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Apps24" FontSize="18"/>
                        <TextBlock Text="Profiles" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="History24" FontSize="18"/>
                        <TextBlock Text="History" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Pulse24" FontSize="18"/>
                        <TextBlock Text="Usage" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Pulse24" FontSize="18"/>
                        <TextBlock Text="Diagnostics" FontSize="14" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <!-- Right: the selected section + a persistent Save/Cancel footer -->
            <Grid Grid.Column="1" Margin="12,4,24,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Shared inline notification; any section can raise it via ShowInfo(...). Floats over
                     the content at the top so it never shifts the section layout. -->
                <ui:InfoBar x:Name="InfoNotice" Grid.Row="0" Panel.ZIndex="1"
                            VerticalAlignment="Top" Margin="2,4,2,0"
                            IsClosable="True" IsOpen="False"/>

                <Grid Grid.Row="0">

                    <!-- ============================ General ============================ -->
                    <Grid x:Name="SectionGeneral">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2,8,0,16" MaxWidth="860" HorizontalAlignment="Left">
                            <TextBlock Text="General" Style="{StaticResource PageTitle}"/>
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="Your microphone, the push-to-talk key, and how Scribe starts."/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="2,0,14,4">
                            <StackPanel MaxWidth="860" HorizontalAlignment="Stretch">
                                <ui:Card Style="{StaticResource SettingCard}">
                                    <StackPanel>
                                        <TextBlock Text="Microphone" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Style="{StaticResource SettingHint}"
                                                   Text="The capture device used while dictating. 'System default' follows your Windows sound settings."/>
                                        <ComboBox x:Name="DeviceCombo" DisplayMemberPath="Name"
                                                  Margin="0,10,0,0" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </ui:Card>

                                <ui:Card Style="{StaticResource SettingCard}">
                                    <StackPanel>
                                        <TextBlock Text="Dictation hotkey" Style="{StaticResource SettingTitle}"/>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:TextBox x:Name="HotkeyBox" Grid.Column="0" IsReadOnly="True"
                                                        VerticalContentAlignment="Center"
                                                        PlaceholderText="Press Set… then a key"
                                                        PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                                        PreviewKeyUp="HotkeyBox_PreviewKeyUp"
                                                        LostFocus="HotkeyBox_LostFocus"/>
                                            <ui:Button x:Name="CaptureButton" Grid.Column="1" Content="Set…"
                                                       Margin="8,0,0,0" MinWidth="72"
                                                       Click="CaptureButton_Click"/>
                                            <ComboBox x:Name="ModeCombo" Grid.Column="2" Width="104" Margin="8,0,0,0"
                                                      VerticalContentAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Style="{StaticResource SettingHint}"
                                                   Text="Hold: keep the full one- or two-key chord down while speaking. Toggle: press once to start, again to stop. Two-key chords reserve both selected keys while Scribe runs, including Windows shortcuts."/>
                                    </StackPanel>
                                </ui:Card>

                                <ui:Card Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Start with Windows" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Style="{StaticResource SettingHint}"
                                                       Text="Launch Scribe automatically when you sign in."/>
                                        </StackPanel>
                                        <ui:ToggleSwitch x:Name="LaunchCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                    </Grid>
                                </ui:Card>

                                <ui:Card Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Keep audio with history" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Style="{StaticResource SettingHint}"
                                                       Text="Store a copy of the captured audio with each history entry."/>
                                        </StackPanel>
                                        <ui:ToggleSwitch x:Name="StoreAudioCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                    </Grid>
                                </ui:Card>

                                <ui:CardExpander x:Name="AdvancedDecodingExpander" Margin="0,10,0,8" IsExpanded="False">
                                    <ui:CardExpander.Header>
                                        <StackPanel>
                                            <TextBlock Text="Advanced decoding" Style="{StaticResource SettingTitle}" FontWeight="SemiBold"/>
                                            <TextBlock Style="{StaticResource SettingHint}" Margin="0,2,0,0"
                                                       Text="Power-user options. The defaults are right for most people — changes take effect after restarting Scribe."/>
                                        </StackPanel>
                                    </ui:CardExpander.Header>
                                    <StackPanel Margin="0,4,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="Higher-accuracy decoding" Style="{StaticResource SettingTitle}"/>
                                                <TextBlock Style="{StaticResource SettingHint}"
                                                           Text="Use beam-search decoding for slightly better accuracy on difficult audio, at a small speed cost."/>
                                            </StackPanel>
                                            <ui:ToggleSwitch x:Name="BeamSearchCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Decode threads" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock x:Name="ThreadsLabel" Grid.Column="1" MinWidth="56"
                                                       TextAlignment="Right" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </Grid>
                                        <Slider x:Name="ThreadsSlider" Minimum="0" Maximum="16"
                                                TickFrequency="1" IsSnapToTickEnabled="True"
                                                Margin="0,8,0,0"
                                                ValueChanged="ThreadsSlider_ValueChanged"/>
                                        <TextBlock Style="{StaticResource SettingHint}"
                                                   Text="CPU threads for transcription (0 = automatic)."/>
                                    </StackPanel>
                                </ui:CardExpander>

                                <!-- Updates: current version, on-demand check, and immediate install. -->
                                <ui:Card Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center">
                                            <TextBlock Text="Updates" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock x:Name="UpdateStatusText" Style="{StaticResource SettingHint}" Margin="0,2,0,0"
                                                       Text="Updates are checked at startup and installed when you quit."/>
                                        </StackPanel>
                                        <ui:Button x:Name="UpdateCheckButton" Grid.Column="1" Content="Check for updates"
                                                   MinWidth="76" VerticalAlignment="Center" Margin="0,0,8,0"
                                                   Click="UpdateCheckButton_Click"/>
                                        <ui:Button x:Name="UpdateApplyButton" Grid.Column="2" Content="Restart &amp; update"
                                                   MinWidth="76" VerticalAlignment="Center" Appearance="Primary"
                                                   Visibility="Collapsed" Click="UpdateApplyButton_Click"/>
                                    </Grid>
                                </ui:Card>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ============================ Dictation ============================ -->
                    <Grid x:Name="SectionDictation" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2,8,0,16" MaxWidth="860" HorizontalAlignment="Left">
                            <TextBlock Text="Dictation" Style="{StaticResource PageTitle}"/>
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="How captures behave and how the finished text lands in your apps."/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="2,0,14,4">
                            <StackPanel MaxWidth="860" HorizontalAlignment="Stretch">
                                <TextBlock Text="Capture" Style="{StaticResource GroupHeader}" Margin="2,4,0,10"/>
                                <ui:Card Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Voice activity detection" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Style="{StaticResource SettingHint}"
                                                       Text="Trim leading/trailing silence and ignore captures with no speech."/>
                                        </StackPanel>
                                        <ui:ToggleSwitch x:Name="VadCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                    </Grid>
                                </ui:Card>
                                <ui:Card Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="End dictation on silence (toggle mode)" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Style="{StaticResource SettingHint}"
                                                       Text="In toggle mode, stop automatically after a few seconds of silence instead of waiting for the second key press. Noisy rooms can trigger this early — leave it off if that happens."/>
                                        </StackPanel>
                                        <ui:ToggleSwitch x:Name="AutoStopCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                    </Grid>
                                </ui:Card>
                                <ui:Card Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Post-processing" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Style="{StaticResource SettingHint}"
                                                       Text="Apply the dictionary, snippets and spacing fix-ups to transcribed text."/>
                                        </StackPanel>
                                        <ui:ToggleSwitch x:Name="PostCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                    </Grid>
                                </ui:Card>

                                <TextBlock Text="Text insertion" Style="{StaticResource GroupHeader}"/>
                                <ui:Card Style="{StaticResource SettingCard}">
                                    <StackPanel>
                                        <TextBlock Text="Insertion method" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Style="{StaticResource SettingHint}"
                                                   Text="Unicode typing works in the widest range of apps and never touches your clipboard. Clipboard paste can be faster, but some apps block it."/>
                                        <ComboBox x:Name="InjectionCombo" Margin="0,10,0,0" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </ui:Card>
                                <ui:Card Style="{StaticResource SettingCard}">
                                    <StackPanel>
                                        <TextBlock Text="Line breaks" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Style="{StaticResource SettingHint}"
                                                   Text="Terminals treat a line break as Enter, so a long dictation with paragraphs can send several partial messages. Smart replaces line breaks with spaces only in terminals."/>
                                        <ComboBox x:Name="NewlineCombo" Margin="0,10,0,0" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </ui:Card>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ============================ Overlay ============================ -->
                    <Grid x:Name="SectionOverlay" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2,8,0,16" MaxWidth="860" HorizontalAlignment="Left">
                            <TextBlock Text="Overlay" Style="{StaticResource PageTitle}"/>
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="The glass recording pill that shows Scribe is listening — and where it lives on your screen."/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="2,0,14,4">
                            <StackPanel MaxWidth="860" HorizontalAlignment="Stretch">
                                <ui:Card Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Show the recording overlay" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Style="{StaticResource SettingHint}"
                                                       Text="A small always-on-top indicator with a live level meter while capturing."/>
                                        </StackPanel>
                                        <ui:ToggleSwitch x:Name="OverlayCheck" Grid.Column="1" VerticalAlignment="Center"/>
                                    </Grid>
                                </ui:Card>

                                <ui:Card Style="{StaticResource SettingCard}">
                                    <StackPanel>
                                        <TextBlock Text="Overlay position" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Style="{StaticResource SettingHint}"
                                                   Text="Click where the pill should appear while you dictate, then try it on your real screen."/>
                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Mini monitor: a 16:9 screen mock-up with nine clickable
                                                 anchor zones and a taskbar strip for orientation. -->
                                            <Border Grid.Column="0" Width="300" Height="170" CornerRadius="8"
                                                    BorderThickness="2"
                                                    BorderBrush="{DynamicResource ControlFillColorSecondaryBrush}"
                                                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <UniformGrid x:Name="OverlayPositionGrid" Grid.Row="0"
                                                                 Rows="3" Columns="3" Margin="4">
                                                        <RadioButton Style="{StaticResource OverlayZone}" Tag="TopLeft"
                                                                     ToolTip="Top left"/>
                                                        <RadioButton Style="{StaticResource OverlayZone}" Tag="TopCenter"
                                                                     ToolTip="Top centre"/>
                                                        <RadioButton Style="{StaticResource OverlayZone}" Tag="TopRight"
                                                                     ToolTip="Top right"/>
                                                        <RadioButton Style="{StaticResource OverlayZone}" Tag="MiddleLeft"
                                                                     ToolTip="Middle left"/>
                                                        <RadioButton Style="{StaticResource OverlayZone}" Tag="Center"
                                                                     ToolTip="Centre"/>
                                                        <RadioButton Style="{StaticResource OverlayZone}" Tag="MiddleRight"
                                                                     ToolTip="Middle right"/>
                                                        <RadioButton Style="{StaticResource OverlayZone}" Tag="BottomLeft"
                                                                     ToolTip="Bottom left"/>
                                                        <RadioButton Style="{StaticResource OverlayZone}" Tag="BottomCenter"
                                                                     ToolTip="Bottom centre (default)"/>
                                                        <RadioButton Style="{StaticResource OverlayZone}" Tag="BottomRight"
                                                                     ToolTip="Bottom right"/>
                                                    </UniformGrid>
                                                    <Border Grid.Row="1" Height="9" Margin="2,0,2,2" CornerRadius="0,0,5,5"
                                                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                            IsHitTestVisible="False"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                                <ui:Button x:Name="OverlayPreviewButton" Content="Preview on screen"
                                                           Icon="{ui:SymbolIcon Eye24}"
                                                           Click="OverlayPreviewButton_Click"/>
                                                <TextBlock Style="{StaticResource SettingHint}" Margin="0,8,0,0"
                                                           Text="Shows the real pill at the selected spot for a moment."/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </ui:Card>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ============================ AI cleanup ============================ -->
                    <Grid x:Name="SectionAi" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2,8,0,16" MaxWidth="860" HorizontalAlignment="Left">
                            <TextBlock Text="AI cleanup" Style="{StaticResource PageTitle}"/>
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="Polish punctuation, grammar and structure with a language model before the text is inserted. Optional — dictation always works without it."/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="2,0,14,4">
                            <StackPanel MaxWidth="860" HorizontalAlignment="Stretch">
                                <ui:Card Style="{StaticResource SettingCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Polish text with AI" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Style="{StaticResource SettingHint}"
                                                       Text="Fix punctuation, capitalization and grammar with an AI model before text is inserted. If the model isn't ready, dictation continues with the raw text."/>
                                        </StackPanel>
                                        <ui:ToggleSwitch x:Name="AiCleanupCheck" Grid.Column="1" VerticalAlignment="Center"
                                                         Checked="AiCleanupCheck_Toggled" Unchecked="AiCleanupCheck_Toggled"/>
                                    </Grid>
                                </ui:Card>

                                <ui:Card Style="{StaticResource SettingCard}">
                                    <StackPanel>
                                        <TextBlock Text="Provider" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Style="{StaticResource SettingHint}"
                                                   Text="Run a model on this PC with Foundry Local (fully offline), use a Microsoft Foundry deployment via your Azure sign-in, or point at any OpenAI-compatible server you already run."/>
                                        <ComboBox x:Name="AiProviderCombo" Margin="0,10,0,0" HorizontalAlignment="Stretch"
                                                  SelectionChanged="AiProviderCombo_SelectionChanged"/>

                                        <!-- Foundry Local (on-device) -->
                                        <StackPanel x:Name="FoundryPanel">
                                            <TextBlock Text="Model" Style="{StaticResource SettingTitle}" Margin="0,16,0,0"/>
                                            <ComboBox x:Name="AiModelBox" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                      IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                                      SelectionChanged="AiModelBox_SelectionChanged"
                                                      DropDownOpened="ModelCombo_DropDownOpened"/>
                                            <TextBlock x:Name="AiModelHint" Style="{StaticResource SettingHint}" Margin="0,6,0,0"/>
                                            <!-- Benchmark guidance so users don't pick blind (see docs/model-leaderboard.md). -->
                                            <TextBlock Style="{StaticResource SettingHint}" Margin="0,6,0,0" TextWrapping="Wrap"
                                                       Text="Recommended: mistral-nemo-12b-instruct (best on-device balance) or phi-4 (best quality). See the model leaderboard in the repo docs for the full comparison."/>

                                            <!-- Load / unload — only one on-device model stays resident at a time -->
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="AiLoadedModelText" Grid.Column="0" VerticalAlignment="Center"
                                                           Style="{StaticResource SettingHint}" Margin="0,0,12,0"
                                                           Text="No on-device model is loaded yet."/>
                                                <ui:Button x:Name="AiLoadButton" Grid.Column="1" Content="Load" MinWidth="80"
                                                           Margin="0,0,8,0" Appearance="Primary" Click="AiLoadButton_Click"/>
                                                <ui:Button x:Name="AiUnloadButton" Grid.Column="2" Content="Unload" MinWidth="80"
                                                           Appearance="Secondary" Click="AiUnloadButton_Click"/>
                                            </Grid>

                                            <Border Margin="0,14,0,0" Padding="12,10" CornerRadius="6"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                        <TextBlock Text="Requires Foundry Local" Style="{StaticResource SettingTitle}" FontSize="13"/>
                                                        <TextBlock x:Name="AiStatusText" Style="{StaticResource SettingHint}" Margin="0,2,0,0"
                                                                   Text="The selected model downloads automatically on first use (about 1–2 GB)."/>
                                                    </StackPanel>
                                                    <ui:Button x:Name="AiCheckButton" Grid.Column="1" Content="Check &amp; list models"
                                                               MinWidth="76" VerticalAlignment="Center"
                                                               Click="AiCheckButton_Click"/>
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <!-- Microsoft Foundry — your Azure sign-in is the default; manual entry lives under Advanced -->
                                        <StackPanel x:Name="AzurePanel" Visibility="Collapsed">
                                            <!-- Primary path: reuse the user's az login and list their deployments -->
                                            <Border Margin="0,14,0,0" Padding="12,10" CornerRadius="6"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                        <TextBlock Text="Use your Azure sign-in" Style="{StaticResource SettingTitle}" FontSize="13"/>
                                                        <TextBlock x:Name="AzureStatusText" Style="{StaticResource SettingHint}" Margin="0,2,0,0"
                                                                   Text="Reuses your 'az login' session — no key needed. Sign in to list the models you've deployed."/>
                                                    </StackPanel>
                                                    <ui:Button x:Name="AzureRefreshButton" Grid.Column="1" Content="Sign in &amp; find models"
                                                               MinWidth="76" VerticalAlignment="Center"
                                                               Click="AzureRefreshButton_Click"/>
                                                </Grid>
                                            </Border>

                                            <!-- Azure CLI: the 'az login' path needs the Azure CLI present. One-click install/update. -->
                                            <Border Margin="0,10,0,0" Padding="12,10" CornerRadius="6"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                        <TextBlock Text="Azure CLI" Style="{StaticResource SettingTitle}" FontSize="13"/>
                                                        <TextBlock x:Name="AzureCliStatusText" Style="{StaticResource SettingHint}" Margin="0,2,0,0"
                                                                   Text="The 'az login' path needs the Azure CLI. Install or update it here (uses winget)."/>
                                                    </StackPanel>
                                                    <ui:Button x:Name="AzureCliButton" Grid.Column="1" Content="Install / update"
                                                               MinWidth="76" VerticalAlignment="Center"
                                                               Click="AzureCliButton_Click"/>
                                                </Grid>
                                            </Border>

                                            <!-- Model picker: a dropdown of the deployments discovered from your sign-in.
                                                 Click to browse them all, or type to quick-filter the list. -->
                                            <TextBlock Text="Model" Style="{StaticResource SettingTitle}" Margin="0,16,0,0"/>
                                            <ComboBox x:Name="AzureModelBox" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                      IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                                      SelectionChanged="AzureModelBox_SelectionChanged"
                                                      DropDownOpened="ModelCombo_DropDownOpened"
                                                      LostFocus="AzureModelBox_LostFocus"/>
                                            <TextBlock x:Name="AzureDeploymentHint" Style="{StaticResource SettingHint}" Margin="0,6,0,0"/>

                                            <!-- Endpoint sits BELOW the picker: picking a model fills it in, so the
                                                 cause-and-effect reads top to bottom. Manual paste still works. -->
                                            <TextBlock Text="Endpoint" Style="{StaticResource SettingTitle}" Margin="0,16,0,0"/>
                                            <ui:TextBox x:Name="AzureEndpointBox" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                        VerticalContentAlignment="Center"
                                                        PlaceholderText="https://my-resource.services.ai.azure.com/"/>
                                            <TextBlock Style="{StaticResource SettingHint}" Margin="0,6,0,0"
                                                       Text="Filled in automatically when you pick a model above. You can also paste your Microsoft Foundry project or Azure OpenAI endpoint here directly."/>

                                            <!-- Advanced: manual endpoint/deployment, API key, or tenant override -->
                                            <ui:CardExpander x:Name="AzureAdvancedExpander" Margin="0,16,0,0" IsExpanded="False">
                                                <ui:CardExpander.Header>
                                                    <StackPanel>
                                                        <TextBlock Text="Advanced" Style="{StaticResource SettingTitle}" FontSize="13"/>
                                                        <TextBlock Style="{StaticResource SettingHint}" Margin="0,2,0,0"
                                                                   Text="Everything here is optional and overrides the choices above when set. Leave these empty to keep using your Azure sign-in."/>
                                                    </StackPanel>
                                                </ui:CardExpander.Header>
                                                <StackPanel Margin="0,4,0,0">
                                                    <TextBlock Text="Deployment name" Style="{StaticResource SettingTitle}"/>
                                                    <ui:TextBox x:Name="AzureDeploymentBox" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                                VerticalContentAlignment="Center"
                                                                PlaceholderText="e.g. gpt-4o"/>
                                                    <TextBlock Style="{StaticResource SettingHint}" Margin="0,6,0,0"
                                                               Text="The model picker above fills this in for you. Editing it overrides the picked model — leave it as-is unless you're naming a deployment by hand."/>

                                                    <TextBlock Text="API key (optional)" Style="{StaticResource SettingTitle}" Margin="0,14,0,0"/>
                                                    <ui:PasswordBox x:Name="AzureApiKeyBox" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                                    VerticalContentAlignment="Center"
                                                                    PlaceholderText="Leave blank to use your Azure sign-in (az login)"/>
                                                    <TextBlock Style="{StaticResource SettingHint}" Margin="0,6,0,0"
                                                               Text="When provided, Scribe authenticates with this key and overrides your Azure sign-in. Leave empty to use az login. Stored encrypted on this PC (Windows DPAPI)."/>

                                                    <TextBlock Text="Tenant ID (optional)" Style="{StaticResource SettingTitle}" Margin="0,14,0,0"/>
                                                    <ui:TextBox x:Name="AzureTenantBox" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                                VerticalContentAlignment="Center"
                                                                PlaceholderText="Entra tenant GUID — leave blank to use your active az login tenant"/>
                                                    <TextBlock Style="{StaticResource SettingHint}" Margin="0,6,0,0"
                                                               Text="When provided, discovery and cleanup use this tenant and override your default az login tenant. Leave empty to use the default. Ignored when an API key is set."/>
                                                </StackPanel>
                                            </ui:CardExpander>
                                        </StackPanel>

                                        <!-- Bring-your-own OpenAI-compatible endpoint (Ollama, LM Studio, OpenRouter...) -->
                                        <StackPanel x:Name="CustomPanel" Visibility="Collapsed">
                                            <TextBlock Text="Endpoint URL" Style="{StaticResource SettingTitle}" Margin="0,16,0,0"/>
                                            <ui:TextBox x:Name="CustomEndpointBox" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                        VerticalContentAlignment="Center"
                                                        PlaceholderText="http://localhost:11434/v1"/>
                                            <TextBlock Style="{StaticResource SettingHint}" Margin="0,6,0,0"
                                                       Text="Any server that speaks the OpenAI chat protocol: Ollama (http://localhost:11434/v1), LM Studio (http://localhost:1234/v1), vLLM, OpenRouter (https://openrouter.ai/api/v1), or api.openai.com/v1. Usually ends in /v1."/>

                                            <TextBlock Text="Model" Style="{StaticResource SettingTitle}" Margin="0,16,0,0"/>
                                            <ui:TextBox x:Name="CustomModelBox" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                        VerticalContentAlignment="Center"
                                                        PlaceholderText="e.g. qwen3:4b, llama3.1:8b, gpt-4o-mini"/>
                                            <TextBlock Style="{StaticResource SettingHint}" Margin="0,6,0,0"
                                                       Text="The model name exactly as the server knows it (for Ollama, what 'ollama list' shows)."/>

                                            <TextBlock Text="API key (optional)" Style="{StaticResource SettingTitle}" Margin="0,16,0,0"/>
                                            <ui:PasswordBox x:Name="CustomApiKeyBox" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                            VerticalContentAlignment="Center"
                                                            PlaceholderText="Leave blank for local servers like Ollama or LM Studio"/>
                                            <TextBlock Style="{StaticResource SettingHint}" Margin="0,6,0,0"
                                                       Text="Only needed for hosted services (OpenRouter, OpenAI). Stored encrypted on this PC (Windows DPAPI). Text only — your audio never leaves this device."/>
                                        </StackPanel>
                                    </StackPanel>
                                </ui:Card>

                                <ui:Card Style="{StaticResource SettingCard}">
                                    <StackPanel>
                                        <TextBlock Text="Writing style" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Style="{StaticResource SettingHint}" Margin="0,2,0,0"
                                                   Text="This guidance is sent to the AI model every time it polishes your dictation. Describe the tone, punctuation and structure you want — or leave the default."/>
                                        <ui:TextBox x:Name="AiWritingStyleBox" Margin="0,10,0,0" HorizontalAlignment="Stretch"
                                                    AcceptsReturn="True" TextWrapping="Wrap" MinHeight="140" MaxHeight="260"
                                                    VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"
                                                    SpellCheck.IsEnabled="True"/>
                                        <ui:Button x:Name="ResetWritingStyleButton" Content="Restore default" Margin="0,10,0,0"
                                                   HorizontalAlignment="Left" Appearance="Secondary"
                                                   Click="ResetWritingStyleButton_Click"/>
                                    </StackPanel>
                                </ui:Card>

                                <ui:Card Style="{StaticResource SettingCard}">
                                    <StackPanel>
                                        <TextBlock Text="Cleanup prompt" Style="{StaticResource SettingTitle}"/>
                                        <TextBlock Style="{StaticResource SettingHint}" Margin="0,2,0,0"
                                                   Text="Which system prompt drives cleanup. Automatic uses a prompt tuned for small on-device models when you run Foundry Local, and the frontier prompt for cloud models. You can force either, or edit them below."/>
                                        <ComboBox x:Name="AiPromptStyleCombo" Margin="0,10,0,0" HorizontalAlignment="Stretch"
                                                  SelectionChanged="AiPromptStyleCombo_SelectionChanged"/>

                                        <ui:CardExpander x:Name="PromptEditExpander" Margin="0,14,0,0" IsExpanded="False">
                                            <ui:CardExpander.Header>
                                                <StackPanel>
                                                    <TextBlock Text="Edit the prompts (advanced)" Style="{StaticResource SettingTitle}" FontSize="13"/>
                                                    <TextBlock Style="{StaticResource SettingHint}" Margin="0,2,0,0"
                                                               Text="Fine-tune the instructions sent to the model. Leave a box on its default to keep tracking future improvements. Each prompt restores on its own."/>
                                                </StackPanel>
                                            </ui:CardExpander.Header>
                                            <StackPanel Margin="0,4,0,0">
                                                <TextBlock Text="Frontier prompt (cloud and capable models)" Style="{StaticResource SettingTitle}"/>
                                                <ui:TextBox x:Name="AiFrontierPromptBox" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                            AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" MaxHeight="220"
                                                            VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"
                                                            SpellCheck.IsEnabled="True"/>
                                                <ui:Button x:Name="ResetFrontierPromptButton" Content="Restore default frontier prompt" Margin="0,8,0,0"
                                                           HorizontalAlignment="Left" Appearance="Secondary"
                                                           Click="ResetFrontierPromptButton_Click"/>

                                                <TextBlock Text="Local prompt (on-device and small models)" Style="{StaticResource SettingTitle}" Margin="0,16,0,0"/>
                                                <ui:TextBox x:Name="AiLocalPromptBox" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                            AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120" MaxHeight="220"
                                                            VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"
                                                            SpellCheck.IsEnabled="True"/>
                                                <ui:Button x:Name="ResetLocalPromptButton" Content="Restore default local prompt" Margin="0,8,0,0"
                                                           HorizontalAlignment="Left" Appearance="Secondary"
                                                           Click="ResetLocalPromptButton_Click"/>
                                            </StackPanel>
                                        </ui:CardExpander>
                                    </StackPanel>
                                </ui:Card>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ============================ Dictionary ============================ -->
                    <Grid x:Name="SectionDictionary" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2,8,0,14" MaxWidth="860" HorizontalAlignment="Left">
                            <TextBlock Text="Dictionary" Style="{StaticResource PageTitle}"/>
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="Replace spoken words or phrases with the spelling you actually want — 'azure' becomes 'Azure', 'dot net' becomes '.NET'. Whole word matches on word boundaries only; clear it for phrase replacement. Edits apply when you save."/>
                        </StackPanel>
                        <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:Button x:Name="DictionarySuggestButton" Content="Learn from history"
                                       Icon="{ui:SymbolIcon Lightbulb24}"
                                       Margin="0,0,8,0" Click="DictionarySuggestButton_Click"
                                       ToolTip="Learn vocabulary from your recent dictations. When an AI model is set up, it works out how terms are spoken and how they should be spelled; otherwise it scans for repeated technical terms."/>
                            <ui:Button x:Name="DictionaryImportButton" Content="Import CSV…"
                                       Icon="{ui:SymbolIcon ArrowDownload24}"
                                       Margin="0,0,8,0" Click="DictionaryImportButton_Click"
                                       ToolTip="Merge entries from a CSV file into this dictionary."/>
                            <ui:Button x:Name="DictionaryExportButton" Content="Export CSV…"
                                       Icon="{ui:SymbolIcon ArrowUpload24}"
                                       Margin="0,0,8,0" Click="DictionaryExportButton_Click"
                                       ToolTip="Save this dictionary as a CSV file to back up or share."/>
                            <ui:Button x:Name="DictionaryTemplateButton" Content="Get template"
                                       Icon="{ui:SymbolIcon DocumentAdd24}"
                                       Click="DictionaryTemplateButton_Click"
                                       ToolTip="Save a starter CSV you can fill in with a spreadsheet and share."/>
                            <StackPanel x:Name="DictionarySuggestBusy" Orientation="Horizontal"
                                        Margin="12,0,0,0" VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <ProgressBar Width="72" Height="4" IsIndeterminate="True"
                                             VerticalAlignment="Center"/>
                                <TextBlock Text="Learning from history…"
                                           Style="{StaticResource SettingHint}"
                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </WrapPanel>
                        <ui:Card Grid.Row="2" Padding="0" Style="{StaticResource FillCard}">
                            <DataGrid x:Name="DictionaryGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="True" CanUserDeleteRows="True"
                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                      Background="Transparent" BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Spoken" Binding="{Binding Pattern}" Width="*"/>
                                    <DataGridTextColumn Header="Replacement" Binding="{Binding Replacement}" Width="*"/>
                                    <DataGridCheckBoxColumn Header="Whole word" Binding="{Binding WholeWord}" Width="Auto"/>
                                    <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ui:Card>
                        <TextBlock Grid.Row="3" Style="{StaticResource SettingHint}" Margin="2,8,2,0"
                                   Text="Tip: type in the empty bottom row to add an entry. Select a row and press Delete to remove it."/>
                    </Grid>

                    <!-- ============================ Libraries ============================ -->
                    <Grid x:Name="SectionLibraries" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2,8,0,14" MaxWidth="860" HorizontalAlignment="Left">
                            <TextBlock Text="Libraries" Style="{StaticResource PageTitle}"/>
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="Turn on ready-made vocabulary packs so Scribe spells technical terms the way you say them. 'a p i m' becomes 'APIM', 'cosmos db' becomes 'Cosmos DB'. Enabled libraries layer on top of your dictionary, and your own entries always win. Import a CSV to add your own. Changes apply when you save."/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <ui:Button x:Name="LibraryImportButton" Content="Import library…"
                                       Icon="{ui:SymbolIcon ArrowDownload24}"
                                       Margin="0,0,8,0" Click="LibraryImportButton_Click"
                                       ToolTip="Add a dictionary library from a CSV file."/>
                            <ui:Button x:Name="LibraryExportButton" Content="Export CSV…"
                                       Icon="{ui:SymbolIcon ArrowUpload24}"
                                       Margin="0,0,8,0" Click="LibraryExportButton_Click"
                                       ToolTip="Save the selected library as a CSV file to back up or share."/>
                            <ui:Button x:Name="LibraryRemoveButton" Content="Remove"
                                       Icon="{ui:SymbolIcon Delete24}"
                                       Click="LibraryRemoveButton_Click"
                                       ToolTip="Remove the selected imported library. Built-in libraries can only be turned off."/>
                        </StackPanel>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="2*" MinWidth="240"/>
                            </Grid.ColumnDefinitions>
                            <ui:Card Grid.Column="0" Padding="0" Style="{StaticResource FillCard}">
                                <DataGrid x:Name="LibraryGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          SelectionMode="Single"
                                          SelectionChanged="LibraryGrid_SelectionChanged"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          Background="Transparent" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="On" Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="Auto"/>
                                        <DataGridTextColumn Header="Library" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="Auto" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Terms" Binding="{Binding Terms}" Width="Auto" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="Auto" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ui:Card>
                            <ui:Card Grid.Column="2" Padding="14" Style="{StaticResource FillCard}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                        <TextBlock x:Name="LibraryDetailName" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="LibraryDetailMeta" Style="{StaticResource SettingHint}" Margin="0,2,0,0"/>
                                        <TextBlock x:Name="LibraryDetailDesc" Style="{StaticResource SettingHint}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <DataGrid x:Name="LibraryTermsGrid" Grid.Row="1"
                                              AutoGenerateColumns="False" IsReadOnly="True"
                                              CanUserAddRows="False" CanUserDeleteRows="False"
                                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                              Background="Transparent" BorderThickness="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Spoken" Binding="{Binding Pattern}" Width="*"/>
                                            <DataGridTextColumn Header="Written" Binding="{Binding Replacement}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock x:Name="LibraryDetailEmpty" Grid.Row="1"
                                               VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"
                                               Style="{StaticResource SettingHint}" TextWrapping="Wrap"
                                               Text="Select a library on the left to see its terms."/>
                                </Grid>
                            </ui:Card>
                        </Grid>
                        <TextBlock Grid.Row="3" Style="{StaticResource SettingHint}" Margin="2,8,2,0"
                                   Text="Tip: click a library to preview its terms on the right. Enable the ones you want, turn off any you don't, then save."/>
                    </Grid>

                    <!-- ============================ Snippets ============================ -->
                    <Grid x:Name="SectionSnippets" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2,8,0,14" MaxWidth="860" HorizontalAlignment="Left">
                            <TextBlock Text="Snippets" Style="{StaticResource PageTitle}"/>
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="Say a trigger phrase — like 'insert my standup update' — and Scribe types the saved template instead. Pick distinctive phrases you wouldn't say by accident. Edits apply when you save."/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ui:Card Grid.Column="0" Padding="8" Margin="0,0,10,0" Style="{StaticResource FillCard}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <ListBox x:Name="SnippetList" Grid.Row="0" BorderThickness="0"
                                             Background="Transparent" DisplayMemberPath="Phrase"
                                             SelectionChanged="SnippetList_SelectionChanged"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                        <ui:Button x:Name="SnippetAddButton" Content="Add" MinWidth="70"
                                                   Margin="0,0,8,0" Click="SnippetAddButton_Click"/>
                                        <ui:Button x:Name="SnippetDeleteButton" Content="Delete" MinWidth="70"
                                                   Click="SnippetDeleteButton_Click"/>
                                    </StackPanel>
                                </Grid>
                            </ui:Card>

                            <ui:Card Grid.Column="1" Padding="18,14" Style="{StaticResource FillCard}">
                                <Grid>
                                    <StackPanel x:Name="SnippetEditor" Visibility="Collapsed" VerticalAlignment="Top">
                                        <TextBlock Text="Trigger phrase" Style="{StaticResource SettingTitle}"/>
                                        <ui:TextBox x:Name="SnippetPhraseBox" Margin="0,8,0,0"
                                                    HorizontalAlignment="Stretch" VerticalContentAlignment="Center"
                                                    PlaceholderText="insert my standup update"
                                                    TextChanged="SnippetPhraseBox_TextChanged"/>
                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Expands to" Style="{StaticResource SettingTitle}"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="Enabled" Style="{StaticResource SettingHint}" Margin="0,0,8,0"
                                                           VerticalAlignment="Center"/>
                                                <ui:ToggleSwitch x:Name="SnippetEnabledCheck" VerticalAlignment="Center"
                                                                 Click="SnippetEnabledCheck_Click"/>
                                            </StackPanel>
                                        </Grid>
                                        <ui:TextBox x:Name="SnippetTemplateBox" Margin="0,8,0,0"
                                                    HorizontalAlignment="Stretch" AcceptsReturn="True"
                                                    TextWrapping="Wrap" MinHeight="220" MaxHeight="380"
                                                    VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"
                                                    SpellCheck.IsEnabled="True"
                                                    TextChanged="SnippetTemplateBox_TextChanged"/>
                                        <TextBlock Style="{StaticResource SettingHint}" Margin="0,6,0,0"
                                                   Text="Line breaks are kept — except in terminals when 'Smart' line-break handling is on, where they become spaces so Enter isn't sent."/>
                                    </StackPanel>
                                    <TextBlock x:Name="SnippetEmptyHint"
                                               Text="Select a snippet on the left, or click Add to create one."
                                               Style="{StaticResource SettingHint}" Margin="0"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </ui:Card>
                        </Grid>
                    </Grid>

                    <!-- ============================ Profiles ============================ -->
                    <Grid x:Name="SectionProfiles" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2,8,0,14" MaxWidth="860" HorizontalAlignment="Left">
                            <TextBlock Text="Profiles" Style="{StaticResource PageTitle}"/>
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="Give different apps different dictation behaviour: formal prose in Outlook, casual in Slack, one terse line in the terminal. The first profile matching the focused app wins; apps with no profile use your global settings."/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="250"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ui:Card Grid.Column="0" Padding="8" Margin="0,0,10,0" Style="{StaticResource FillCard}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <ListBox x:Name="ProfileList" Grid.Row="0" BorderThickness="0"
                                             Background="Transparent" DisplayMemberPath="Name"
                                             SelectionChanged="ProfileList_SelectionChanged"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                        <ui:Button x:Name="ProfileAddButton" Content="Add" MinWidth="70"
                                                   Margin="0,0,8,0" Click="ProfileAddButton_Click"/>
                                        <ui:Button x:Name="ProfileDeleteButton" Content="Delete" MinWidth="70"
                                                   Click="ProfileDeleteButton_Click"/>
                                    </StackPanel>
                                </Grid>
                            </ui:Card>

                            <ui:Card Grid.Column="1" Padding="18,14" Style="{StaticResource FillCard}">
                                <Grid>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="ProfileEditor" Visibility="Collapsed" VerticalAlignment="Top">
                                            <TextBlock Text="Profile name" Style="{StaticResource SettingTitle}"/>
                                            <ui:TextBox x:Name="ProfileNameBox" Margin="0,8,0,0"
                                                        HorizontalAlignment="Stretch" VerticalContentAlignment="Center"
                                                        PlaceholderText="e.g. Email"
                                                        TextChanged="ProfileNameBox_TextChanged"/>

                                            <TextBlock Text="Apps (process names)" Style="{StaticResource SettingTitle}" Margin="0,16,0,0"/>
                                            <ui:TextBox x:Name="ProfileProcessesBox" Margin="0,8,0,0"
                                                        HorizontalAlignment="Stretch" VerticalContentAlignment="Center"
                                                        PlaceholderText="OUTLOOK, olk, thunderbird"
                                                        TextChanged="ProfileProcessesBox_TextChanged"/>
                                            <TextBlock Style="{StaticResource SettingHint}" Margin="0,6,0,0"
                                                       Text="Comma-separated process names, without .exe (Task Manager's Details tab shows them). Examples: OUTLOOK for classic Outlook, olk for new Outlook, slack, WindowsTerminal, Code for VS Code."/>

                                            <TextBlock Text="Writing style for these apps" Style="{StaticResource SettingTitle}" Margin="0,16,0,0"/>
                                            <ui:TextBox x:Name="ProfileStyleBox" Margin="0,8,0,0"
                                                        HorizontalAlignment="Stretch" AcceptsReturn="True"
                                                        TextWrapping="Wrap" MinHeight="120" MaxHeight="220"
                                                        VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"
                                                        SpellCheck.IsEnabled="True"
                                                        TextChanged="ProfileStyleBox_TextChanged"/>
                                            <TextBlock Style="{StaticResource SettingHint}" Margin="0,6,0,0"
                                                       Text="Leave blank to keep your global writing style. Needs AI cleanup to be enabled to take effect."/>

                                            <TextBlock Text="Line breaks in these apps" Style="{StaticResource SettingTitle}" Margin="0,16,0,0"/>
                                            <ComboBox x:Name="ProfileNewlineCombo" Margin="0,8,0,0" HorizontalAlignment="Stretch"
                                                      SelectionChanged="ProfileNewlineCombo_SelectionChanged"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                    <TextBlock x:Name="ProfileEmptyHint"
                                               Text="Select a profile on the left, or click Add to create one."
                                               Style="{StaticResource SettingHint}" Margin="0"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </ui:Card>
                        </Grid>
                    </Grid>

                    <!-- ============================ History ============================ -->
                    <Grid x:Name="SectionHistory" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2,8,0,14" MaxWidth="860" HorizontalAlignment="Left">
                            <TextBlock Text="History" Style="{StaticResource PageTitle}"/>
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="Review recent dictations, copy text, or remove entries. History stays on this PC."/>
                        </StackPanel>
                        <ui:Card Grid.Row="1" Padding="0" Style="{StaticResource FillCard}">
                            <Grid>
                                <DataGrid x:Name="HistoryGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          IsReadOnly="True" HeadersVisibility="Column"
                                          SelectionMode="Single" GridLinesVisibility="Horizontal"
                                          Background="Transparent" BorderThickness="0"
                                          SelectionChanged="HistoryGrid_SelectionChanged"
                                          MouseDoubleClick="HistoryGrid_MouseDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="When" Binding="{Binding When}" Width="Auto"/>
                                        <DataGridTextColumn Header="Text" Binding="{Binding Text}" Width="*">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                    <Setter Property="ToolTip" Value="{Binding Text}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="App" Binding="{Binding App}" Width="Auto"/>
                                        <DataGridTextColumn Header="Audio" Binding="{Binding Audio}" Width="Auto"/>
                                        <DataGridTextColumn Header="Decode" Binding="{Binding Decode}" Width="Auto"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock x:Name="HistoryEmptyHint"
                                           Text="No dictations yet. Hold your hotkey and speak, then your dictations will appear here."
                                           Visibility="Collapsed"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="32" TextAlignment="Center" TextWrapping="Wrap"
                                           Style="{StaticResource SettingHint}"/>
                            </Grid>
                        </ui:Card>
                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <ui:Button x:Name="HistoryClearButton" Content="Clear all…"
                                       HorizontalAlignment="Left" Click="HistoryClearButton_Click"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ui:Button x:Name="HistoryCopyButton" Content="Copy text" MinWidth="96"
                                           Margin="0,0,8,0" Click="HistoryCopyButton_Click" IsEnabled="False"/>
                                <ui:Button x:Name="HistoryDeleteButton" Content="Delete" MinWidth="96"
                                           Click="HistoryDeleteButton_Click" IsEnabled="False"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- ============================ Usage ============================ -->
                    <Grid x:Name="SectionUsage" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="2,8,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                                <TextBlock Text="Usage" Style="{StaticResource PageTitle}"/>
                                <TextBlock Style="{StaticResource PageSubtitle}"
                                           Text="Your local dictation activity and recurring terminology. Nothing is uploaded when this page opens."/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <ComboBox x:Name="UsagePeriodBox" Width="150" Margin="0,0,8,0"
                                          SelectionChanged="UsagePeriodBox_SelectionChanged"/>
                                <ui:Button Content="Refresh" MinWidth="84" Click="UsageRefreshButton_Click"/>
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="2,0,14,4">
                            <StackPanel MaxWidth="900" HorizontalAlignment="Stretch">
                                <TextBlock x:Name="UsageCoverageText" Style="{StaticResource SettingHint}"
                                           Margin="0,0,0,10"/>

                                <ui:Card Padding="18,14" Margin="0,0,0,12">
                                    <UniformGrid Columns="5">
                                        <StackPanel>
                                            <TextBlock x:Name="UsageDictationsText" FontSize="22" FontWeight="SemiBold"/>
                                            <TextBlock Text="dictations" Style="{StaticResource SettingHint}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock x:Name="UsageWordsText" FontSize="22" FontWeight="SemiBold"/>
                                            <TextBlock Text="words" Style="{StaticResource SettingHint}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock x:Name="UsageActiveDaysText" FontSize="22" FontWeight="SemiBold"/>
                                            <TextBlock Text="active days" Style="{StaticResource SettingHint}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock x:Name="UsageSpeechText" FontSize="22" FontWeight="SemiBold"/>
                                            <TextBlock Text="speech" Style="{StaticResource SettingHint}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock x:Name="UsageAverageText" FontSize="22" FontWeight="SemiBold"/>
                                            <TextBlock Text="words per dictation" Style="{StaticResource SettingHint}"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </ui:Card>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:Card Grid.Column="0" Padding="18,14" Style="{StaticResource FillCard}">
                                        <StackPanel>
                                            <TextBlock Text="Top apps" Style="{StaticResource SettingTitle}"/>
                                            <DataGrid x:Name="UsageAppsGrid" Margin="0,10,0,0" MaxHeight="230"
                                                      AutoGenerateColumns="False" IsReadOnly="True"
                                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                      Background="Transparent" BorderThickness="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="App" Binding="{Binding Name}" Width="*"/>
                                                    <DataGridTextColumn Header="Dictations" Binding="{Binding Dictations}" Width="Auto"/>
                                                    <DataGridTextColumn Header="Words" Binding="{Binding Words}" Width="Auto"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </ui:Card>
                                    <ui:Card Grid.Column="2" Padding="18,14" Style="{StaticResource FillCard}">
                                        <StackPanel>
                                            <TextBlock Text="Trend" Style="{StaticResource SettingTitle}"/>
                                            <DataGrid x:Name="UsageTrendGrid" Margin="0,10,0,0" MaxHeight="230"
                                                      AutoGenerateColumns="False" IsReadOnly="True"
                                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                                      Background="Transparent" BorderThickness="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Period" Binding="{Binding Period}" Width="*"/>
                                                    <DataGridTextColumn Header="Dictations" Binding="{Binding Dictations}" Width="Auto"/>
                                                    <DataGridTextColumn Header="Words" Binding="{Binding Words}" Width="Auto"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </ui:Card>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:Card Grid.Column="0" Padding="18,14" Style="{StaticResource FillCard}">
                                        <StackPanel>
                                            <TextBlock Text="Recognized technologies" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Terms already covered by your enabled dictionary and libraries."
                                                       Style="{StaticResource SettingHint}"/>
                                            <ItemsControl x:Name="UsageKnownTerms" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </ui:Card>
                                    <ui:Card Grid.Column="2" Padding="18,14" Style="{StaticResource FillCard}">
                                        <StackPanel>
                                            <TextBlock Text="Recurring terminology" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock Text="Conservative jargon candidates not yet covered by your dictionary."
                                                       Style="{StaticResource SettingHint}"/>
                                            <ItemsControl x:Name="UsageNovelTerms" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </ui:Card>
                                </Grid>

                                <ui:Card Padding="18,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="AI insight" Style="{StaticResource SettingTitle}"/>
                                            <TextBlock x:Name="UsageInsightText" Style="{StaticResource SettingHint}"
                                                       Text="Ask your configured cleanup model for a short summary of aggregate totals and recurring terms."/>
                                        </StackPanel>
                                        <ui:Button x:Name="UsageInsightButton" Grid.Column="1" Content="Generate insight"
                                                   MinWidth="126" Margin="16,0,0,0" VerticalAlignment="Center"
                                                   Click="UsageInsightButton_Click"/>
                                    </Grid>
                                </ui:Card>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ============================ Diagnostics ============================ -->
                    <Grid x:Name="SectionDiagnostics" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2,8,0,14" MaxWidth="860" HorizontalAlignment="Left">
                            <TextBlock Text="Diagnostics" Style="{StaticResource PageTitle}"/>
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="How fast dictation runs on this PC, and what happened when AI cleanup fell back to raw text. Everything here is computed from data already on your disk — nothing is collected."/>
                        </StackPanel>

                        <!-- Local latency stats from stored history — decode only. -->
                        <ui:Card Grid.Row="1" Padding="18,14" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Performance — last 7 days" Style="{StaticResource SettingTitle}"/>
                                <TextBlock x:Name="StatsSummaryText" Style="{StaticResource SettingHint}" Margin="0,2,0,0"
                                           Text="No dictations recorded in the last week."/>
                                <UniformGrid x:Name="StatsGrid" Columns="4" Margin="0,12,0,0" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock x:Name="StatDecodeP50" FontSize="22" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="decode, typical (P50)" Style="{StaticResource SettingHint}"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock x:Name="StatDecodeP95" FontSize="22" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="decode, slow runs (P95)" Style="{StaticResource SettingHint}"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock x:Name="StatRtfP50" FontSize="22" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="speed, typical (RTF P50)" Style="{StaticResource SettingHint}"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock x:Name="StatRtfP95" FontSize="22" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="speed, slow runs (RTF P95)" Style="{StaticResource SettingHint}"/>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </ui:Card>

                        <TextBlock Grid.Row="2" Style="{StaticResource GroupHeader}" Margin="2,0,0,10"
                                   Text="AI cleanup failures — last 7 days"/>
                        <ui:Card Grid.Row="3" Padding="0" Style="{StaticResource FillCard}">
                            <Grid>
                                <DataGrid x:Name="FailuresGrid"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          CanUserAddRows="False" CanUserDeleteRows="False"
                                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                          Background="Transparent" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="When" Binding="{Binding When}" Width="Auto"/>
                                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="Auto"/>
                                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock x:Name="NoFailuresText" Text="No failures recorded — cleanup has been healthy."
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Style="{StaticResource SettingHint}" Margin="0"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </ui:Card>
                        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <ui:Button x:Name="ClearFailuresButton" Content="Clear failures"
                                       MinWidth="120" Click="ClearFailuresButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- Footer: explicit save model, always visible -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <ui:Button x:Name="SaveButton" Content="Save" Appearance="Primary"
                               MinWidth="96" Margin="0,0,8,0" Click="SaveButton_Click" IsDefault="True"
                               ToolTip="Save your changes and keep this window open."/>
                    <ui:Button x:Name="SaveCloseButton" Content="Save and close"
                               MinWidth="120" Margin="0,0,8,0" Click="SaveCloseButton_Click"
                               ToolTip="Save your changes and close the window."/>
                    <ui:Button x:Name="CancelButton" Content="Cancel"
                               MinWidth="96" Click="CancelButton_Click" IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>

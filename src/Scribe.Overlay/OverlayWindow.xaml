<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Scribe.Overlay.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.Resources>
            <Storyboard x:Key="PulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
                <DoubleAnimation Storyboard.TargetName="RecDot"
                                 Storyboard.TargetProperty="Opacity"
                                 From="1.0" To="0.25" Duration="0:0:0.7"/>
            </Storyboard>
            <Storyboard x:Key="ProcessingStoryboard">
                <DoubleAnimation Storyboard.TargetName="Dot1Transform" Storyboard.TargetProperty="Y"
                                 From="0" To="-5" Duration="0:0:0.45" AutoReverse="True"
                                 RepeatBehavior="Forever" BeginTime="0:0:0">
                    <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="Dot2Transform" Storyboard.TargetProperty="Y"
                                 From="0" To="-5" Duration="0:0:0.45" AutoReverse="True"
                                 RepeatBehavior="Forever" BeginTime="0:0:0.12">
                    <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="Dot3Transform" Storyboard.TargetProperty="Y"
                                 From="0" To="-5" Duration="0:0:0.45" AutoReverse="True"
                                 RepeatBehavior="Forever" BeginTime="0:0:0.24">
                    <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>

        <!-- Faux outer bloom: two translucent rounded rings behind the card give a soft glow rim
             without a blur effect (WinUI has no WPF-style DropShadowEffect; a real composition
             DropShadow glow lands in Phase 1). Null/!HitTest so they never block clicks. -->
        <Border x:Name="OuterGlow" Margin="21" CornerRadius="23" BorderThickness="6"
                BorderBrush="#268FB2FF" IsHitTestVisible="False"/>
        <Border x:Name="OuterGlowInner" Margin="25" CornerRadius="21" BorderThickness="3"
                BorderBrush="#598FB2FF" IsHitTestVisible="False"/>
        <Border x:Name="OuterGlowFailed" Margin="21" CornerRadius="23" BorderThickness="6"
                BorderBrush="#33E5484D" IsHitTestVisible="False" Visibility="Collapsed"/>

        <Border x:Name="Card" Margin="27" CornerRadius="18" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#802B2F38" Offset="0.0"/>
                    <GradientStop Color="#73191C22" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#4DFFFFFF" Offset="0.0"/>
                    <GradientStop Color="#0DFFFFFF" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Grid>
                <!-- Specular sheen across the top so the panel reads like glass -->
                <Border CornerRadius="18,18,0,0" VerticalAlignment="Top" Height="27" IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#1AFFFFFF" Offset="0.0"/>
                            <GradientStop Color="#00FFFFFF" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Red wash over the card face during the brief AI-failure flash -->
                <Border x:Name="FailedTint" CornerRadius="18" Visibility="Collapsed" IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#E6B3261A" Offset="0.0"/>
                            <GradientStop Color="#D98C1410" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <Grid Margin="14,9">
                    <!-- Listening: pulsing record dot + input-level meter -->
                    <Grid x:Name="ListeningContent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Ellipse x:Name="RecDot" Grid.Column="0" Width="10" Height="10"
                                 Margin="2,0,10,0" Fill="#E5484D" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusText" Text="Listening…"
                                       Foreground="#FFFFFFFF" FontSize="12" FontWeight="SemiBold"/>
                            <Border Margin="0,6,0,0" Width="140" Height="5" CornerRadius="3"
                                    Background="#26FFFFFF" HorizontalAlignment="Left">
                                <Border x:Name="MeterFill" HorizontalAlignment="Left" Width="70" CornerRadius="3">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#34D399" Offset="0.0"/>
                                            <GradientStop Color="#FBBF24" Offset="0.7"/>
                                            <GradientStop Color="#E5484D" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Processing: bouncing dots while transcribing / AI polishing -->
                    <Grid x:Name="ProcessingContent" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="2,0,10,0">
                            <Ellipse Width="7" Height="7" Margin="0,0,4,0" Fill="#8AB4F8">
                                <Ellipse.RenderTransform><TranslateTransform x:Name="Dot1Transform"/></Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse Width="7" Height="7" Margin="0,0,4,0" Fill="#8AB4F8">
                                <Ellipse.RenderTransform><TranslateTransform x:Name="Dot2Transform"/></Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse Width="7" Height="7" Fill="#8AB4F8">
                                <Ellipse.RenderTransform><TranslateTransform x:Name="Dot3Transform"/></Ellipse.RenderTransform>
                            </Ellipse>
                        </StackPanel>

                        <TextBlock x:Name="ProcessingText" Grid.Column="1" Text="Polishing…"
                                   VerticalAlignment="Center" Foreground="#FFFFFFFF"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </Grid>

                    <!-- AI cleanup failed: brief red notice while falling back to raw text -->
                    <Grid x:Name="FailedContent" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="&#x26A0;" VerticalAlignment="Center"
                                   Margin="2,0,10,0" FontSize="16" Foreground="#FFFFFFFF"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Intelligence failed" Foreground="#FFFFFFFF"
                                       FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="FailedReasonText" Text="Used raw transcription"
                                       Foreground="#D6FFFFFF" FontSize="10" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

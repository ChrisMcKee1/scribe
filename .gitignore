# Build output
[Bb]in/
[Oo]bj/
[Oo]ut/
artifacts/

# Publish + installer artifacts (produced by build/pack.ps1 — never committed; they are
# attached to the GitHub Release instead, where the Velopack updater fetches them).
publish/
releases/

# Models (large ONNX files — fetched via scripts/Download-Models.ps1, never committed).
# They live next to the app that depends on them (src/Scribe.App/models) and the build copies
# them into the output. The *.onnx catch-all is a backstop; the C# Models/ source folders
# (e.g. src/Scribe.Core/Models/) contain no .onnx and are unaffected.
/src/Scribe.App/models/
*.onnx

# Audio scratch / captures
*.wav
!**/test_wavs/*.wav

# Rider / VS / VS Code
.vs/
.idea/
*.user
*.suo
*.userprefs
.vscode/

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/

# Test / coverage
[Tt]est[Rr]esults/
coverage*.json
coverage*.xml
*.coverage
*.trx

# OS
Thumbs.db
desktop.ini
.DS_Store

# Logs / local app data
*.log
